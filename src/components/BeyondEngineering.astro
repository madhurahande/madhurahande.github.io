---
import { books, poem } from "../data/beyond";

const interests = [
  {
    icon: "",
    title: "",
    description:
     "",
       },

];
---


<section class="section" id="beyond-engineering">
  <div class="container">

    <div class="section-header">
      <p class="section-label">Beyond Engineering</p>

      <h2 class="section-title">
        Curiosity extends beyond technology.
      </h2>

      <p class="section-subtitle">
      Engineering is an important part of who I am, and so are the interests that shape how I observe, learn, and create.
      </p>
    </div>

    <!-- Rangoli -->
    <div class="rangoli card">

      <div class="section-content">
        <h3 class="interest-title">Rangoli</h3>

        <p class="interest-description">
          Rangoli is one of my favorite creative pursuits. I enjoy transforming simple geometric patterns into intricate designs, where every composition is guided by symmetry, balance, and attention to detail. It is a practice that encourages patience, careful observation, and an appreciation for the creative process itself.
        </p>
      </div>


        <div class="rangoli-gallery">
         
        <img src="/img/rangoli/r1.jpeg" alt="Rangoli design">

        <img src="/img/rangoli/r2.jpeg" alt="Rangoli design">

        <img src="/img/rangoli/r6.jpeg" alt="Rangoli design">

        <img src="/img/rangoli/r9.jpeg" alt="Rangoli design">

        </div>

      </div>


    <!-- Books -->
    <div class="books card">

      <div class="section-content">
        <h3 class="interest-title">Books That Stayed With Me</h3>

        <p class="interest-description">
          Books that shaped my thinking and continue to stay with me long after I finished reading them.
        </p>
      </div>

        <div class="books-grid">
          {books.map((book) => (
           <a
            href={book.link}
            target="_blank"
            rel="noopener noreferrer"
            class="book-card"
          >
            <h4>{book.title}</h4>
            <span class="book-author">{book.author}</span>
            <p>{book.reflection}</p>
          </a>
          ))}
        </div>

      </div>


    <!-- Poetry -->
    <div class="poetry card">

      <div class="section-content">
        <h3 class="interest-title">Poetry</h3>

        <p class="interest-description">
          A few poems that I revisit for their language, perspective and timeless ideas.
        </p>
      </div>

        <div class="poetry-grid">
          {poem.map((item) => (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="poem-card"
            >
              <h4>{item.title}</h4>
              <span class="book-author">{item.author}</span>
              <p>{item.reflection}</p>
            </a>
          ))}
        </div>

      </div>

    </div>

  </div>
</section>