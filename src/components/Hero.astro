---
import { site } from '../data/site';
---

<section class="hero section" id="top">
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1>{site.name}</h1>
      <p class="hero-tagline">{site.heroTagline}</p>
      <p class="hero-eyebrow">{site.gradSchoolNote}</p>
      <div class="hero-pitch">
      {site.heroPitch.map((paragraph) => (
      <p>{paragraph}</p>
      ))}
      </div>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#work">Explore my work</a>
        <a class="btn btn-secondary" href={site.resumePath} download>Download resume</a>
        <a class="btn btn-secondary" href="#contact">Get in touch</a>
      </div>
      <div class="hero-stats">
        <div>
          <strong>{site.stats.IndustryExperienceYears}+ years</strong>
          <span>Industry Experience </span>
        </div>
        <div>
          <strong>{site.stats.UniversityRank}<sup>th</sup></strong>
          <span>Pune University Rank</span>
        </div>
       <div>
          <strong>{site.stats.ABURoboconRank}<sup>th</sup></strong>
          <span>
            <a
              href="https://en.wikipedia.org/wiki/ABU_Robocon"
              target="_blank"
              rel="noopener noreferrer"
            >
              ABU Robocon All India Rank ↗
            </a>
          </span>
        </div>
      </div>
    </div>
    <div class="hero-visual card">
      <img src={site.profileImage} alt={`Portrait of ${site.name}`} width="480" height="560" />
      <div class="hero-visual-caption">
        <p>{site.location}</p>
        <a href={site.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 3rem;
    background: var(--hero-gradient);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 0.5fr;
    gap: 2.5rem;
    align-items: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent-strong);
    margin: 0 0 1rem;
    max-width: 36rem;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
  }

  .hero-tagline {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }
  
  .hero-pitch {
    max-width: 80rem;
    margin-bottom: 2rem;
  }

  .hero-pitch p {
    color: var(--text-muted);
    margin: 0 0 1rem;
    line-height: 1.75;
  }

  .hero-pitch p:last-child {
    margin-bottom: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .hero-stats div {
    padding: 1rem;
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-elevated) 80%, transparent);
    border: 1px solid var(--border);
  }

  .hero-stats strong {
    display: block;
    font-size: 1.1rem;
  }

  .hero-stats span {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .hero-visual {
    max-width: 260px;
    margin-left: auto;
    text-align: center;
    background: none;
    border: none;
    box-shadow: none;
}

.hero-visual img {
    width: 220px;
    height: 250px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--border);
}

.hero-visual-caption {
    border: none;
    padding-top: 1rem;
    flex-direction: column;
    gap: .4rem;
}
@media (max-width:900px){

.hero-copy{
    display:flex;
    flex-direction:column;
}
 .hero-grid {
    grid-template-columns: 1fr;
  }

    .hero-visual {
      margin-left: 0;
      margin-right: 0;
      justify-self: center;   /* Mobile: center */
    }

.hero-eyebrow,
.hero-pitch,
.hero-actions,
.hero-stats{
    order:3;
}

}

  @media (max-width: 560px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
