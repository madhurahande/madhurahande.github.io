---
import { site } from '../data/site';
---

<section class="section" id="contact">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Contact</p>
      <h2 class="section-title">Let’s connect</h2>
      <p class="section-subtitle">
        Whether you're interested in embedded systems, research collaboration, graduate opportunities, or simply discussing technology, I'd be happy to connect.
      </p>
    </div>

    <div class="contact-grid">
      <div class="contact-info">
        <div class="info-card card">
          <h3>Location</h3>
          <p>{site.address}</p>
        </div>
        <div class="info-card card">
          <h3>Email</h3>
          <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        </div>
        <div class="info-card card">
          <h3>Phone</h3>
          <p>{site.phone}</p>
        </div>
        <div class="info-card card">
          <h3>LinkedIn</h3>
          <p><a href={site.linkedin} target="_blank" rel="noreferrer">madhura-hande-deshmukh</a></p>
        </div>
      </div>

      <form class="contact-form card" action={site.formspreeEndpoint} method="POST">
        <h3>Send a message</h3>
        <div class="field-row">
          <label>
            <span class="sr-only">Your name</span>
            <input type="text" name="name" placeholder="Your name" required />
          </label>
          <label>
            <span class="sr-only">Your email</span>
            <input type="email" name="email" placeholder="Your email" required />
          </label>
        </div>
        <label>
          <span class="sr-only">Subject</span>
          <input type="text" name="subject" placeholder="Subject" required />
        </label>
        <label>
          <span class="sr-only">Message</span>
          <textarea name="message" rows="6" placeholder="Message" required></textarea>
        </label>
        <button class="btn btn-primary" type="submit">Send message</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .contact-info {
    display: grid;
    gap: 1rem;
  }

  .info-card,
  .contact-form {
    padding: 1.25rem;
  }

  .info-card h3,
  .contact-form h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .info-card p {
    margin: 0;
    color: var(--text-muted);
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  input,
  textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font: inherit;
  }

  input:focus,
  textarea:focus {
    outline: 2px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-color: var(--accent);
  }

  @media (max-width: 900px) {
    .contact-grid,
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>
