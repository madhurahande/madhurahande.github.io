---
import { site } from '../data/site';
import { skillGroups, languages } from '../data/experience';
---

<section class="section" id="about">
  <div class="container">
    <div class="section-header">
      <p class="section-label">About</p>
      <h2 class="section-title">Building systems with curiosity, reliability and purpose</h2>
      <p class="section-subtitle">
        My interest in embedded systems began with a simple question: how does software enable hardware to sense, decide, and interact with the physical world? That curiosity led me to Instrumentation and Control Engineering, where I discovered the fascinating intersection of electronics, software, and real-world systems.
      </p>
    </div>

    <div class="about-grid">
      <div class="about-card card">
        <h3>Engineering Journey</h3>
        <p>
          During university, robotics competitions taught me to solve engineering problems under real-world constraints while collaborating across mechanical, electrical, and software disciplines. Today, I develop firmware for safety-critical medical devices, where reliability, precision, and thoughtful system design are essential.        </p>
        <p>
          Although my professional experience is rooted in healthcare technology, my broader interests include embedded systems, real-time computing, embedded Linux, intelligent sensing, and system architecture. I'm continually learning, building, and exploring new ideas that help me become a better engineer.
        </p>
        <ul class="about-meta">
          <li><span>Degree</span> BE Instrumentation & Control</li>
          <li><span>Location</span> {site.location}</li>
          <li><span>Email</span> <a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><span>Phone</span> {site.phone}</li>
        </ul>
      </div>

      <div class="skills-panel">
        {skillGroups.map((group) => (
          <div class="skill-group card">
            <h3>{group.title}</h3>
            <ul class="tag-list">
              {group.skills.map((skill) => (
                <li><span class="chip">{skill}</span></li>
              ))}
            </ul>
          </div>
        ))}

        <div class="skill-group card">
          <h3>Languages</h3>
          <ul class="tag-list">
            {languages.map((language) => (
              <li><span class="chip">{language}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 1.5rem;
    align-items: start;
  }

  .about-card,
  .skill-group {
    padding: 1.5rem;
  }

  .about-card h3,
  .skill-group h3 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .about-card p {
    color: var(--text-muted);
  }

  .about-meta {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.75rem;
  }

  .about-meta li {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.75rem;
    font-size: 0.95rem;
  }

  .about-meta span {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .skills-panel {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
