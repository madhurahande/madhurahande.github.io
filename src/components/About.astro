---
import { site } from '../data/site';
import { skillGroups, languages } from '../data/experience';
---

<section class="section" id="about">
  <div class="container">
    <div class="section-header">
      <p class="section-label">About</p>
      <h2 class="section-title">Building systems with curiosity, reliability and purpose</h2>
       <p class="section-subtitle">
        I enjoy working at the intersection of hardware and software, where a few lines of firmware can directly influence how a physical system behaves. My work has exposed me to safety-critical medical devices, robotics, industrial automation, and embedded control systems, but what motivates me most is understanding complete systems rather than isolated components.
        </p>
        <p>
          I am particularly interested in embedded architecture, real-time software, intelligent sensing, and designing reliable systems that solve meaningful real-world problems. As I continue to grow, I hope to contribute to technologies that are robust, human-centered, and built on strong engineering principles.
        </p>
    </div>

    <div class="about-grid">

      <div class="skills-panel">
        {skillGroups.map((group) => (
          <div class="skill-group card">
            <h3>{group.title}</h3>
            <ul class="tag-list">
              {group.skills.map((skill) => (
                <li><span class="chip">{skill}</span></li>
              ))}
            </ul>
          </div>
        ))}

        <div class="skill-group card">
          <h3>Languages</h3>
          <ul class="tag-list">
            {languages.map((language) => (
              <li><span class="chip">{language}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .about-card,
  .skill-group {
    padding: 1.5rem;
  }

@media (max-width:768px){
.skill-group{
    padding:1rem;
}

}

  .about-card h3,
  .skill-group h3 {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .about-card p {
    color: var(--text-muted);
  }

  .about-meta {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.75rem;
  }

  .about-meta li {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.75rem;
    font-size: 0.95rem;
  }

  .about-meta span {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .skills-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

@media (max-width: 900px) {
  .skills-panel {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .skills-panel {
    grid-template-columns: 1fr;
  }
}


  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
