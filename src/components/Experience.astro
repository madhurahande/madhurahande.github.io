---
import { experience, education } from '../data/experience';
---

<section class="section" id="experience">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Engineering Journey</p>
      <h2 class="section-title">Industry experience and academic foundation</h2>
      <p class="section-subtitle">
        My journey from a curious engineering student to an embedded systems engineer has been shaped by robotics, industrial automation, and the development of safety-critical medical devices. Each experience strengthened my technical foundation while deepening my interest in designing reliable intelligent systems.
        <!-- My journey has taken me from robotics competitions and industrial automation to developing embedded software for safety-critical medical devices, with each experience strengthening my understanding of reliable embedded systems. -->
        <!-- Over the past two years, I've contributed to the development of embedded systems across medical devices, robotics, and automation. My work has focused on building reliable firmware, integrating hardware and software, improving signal quality, and solving complex engineering challenges. -->
      </p>
    </div>

    <div class="timeline-grid">
    
      <div>
        <div class="timeline">
          {experience.map((item) => (
            <article class="timeline-item card">
              <div class="timeline-head">
                {item.logo && <img src={item.logo} alt="" width="48" height="48" class="logo" />}
                <div>
                  <h4>{item.role}</h4>
                  <p class="org">
                    {item.companyUrl ? (
                      <a href={item.companyUrl} target="_blank" rel="noreferrer">{item.company}</a>
                    ) : (
                      item.company
                    )}
                  </p>
                  <p class="dates">{item.start} — {item.end}</p>
                </div>
              </div>
              <ul>
                {item.highlights.map((point) => (
                  <ul>{point}</ul>
                ))}
              </ul>
              {item.achievements && (
                <div class="achievements">
                  {item.achievements.map((achievement) => (
                    <div class="achievement">
                      <li><strong>{achievement.title}</strong></li>
                      <span>{achievement.date}</span>
                      {achievement.certificateUrl && (
                        <a href={achievement.certificateUrl} target="_blank" rel="noreferrer">
                          View certificate
                        </a>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
        
        <div class="timeline">
          {education.map((item) => (
            <article class="timeline-item card">
              <div class="timeline-head">
                {item.logo && <img src={item.logo} alt="" width="48" height="48" class="logo" />}
                <div>
                  <h4>{item.degree}</h4>
                  <p class="org">
                    {item.institutionUrl ? (
                      <a href={item.institutionUrl} target="_blank" rel="noreferrer">{item.institution}</a>
                    ) : (
                      item.institution
                    )}
                  </p>
                  <p class="dates">{item.start} — {item.end}</p>
                </div>
              </div>
              <ul>
                {item.details.map((detail) => (
                  <ul>{detail}</ul>
                ))}
              </ul>
              {item.achievements && (
                <div class="achievements">
                  {item.achievements.map((achievement) => (
                    <div class="achievement">
                      <li><strong>{achievement.title}</strong></li>
                      <span>{achievement.date}</span>
                      {achievement.certificateUrl && (
                        <a href={achievement.certificateUrl} target="_blank" rel="noreferrer">
                          View certificate
                        </a>
                      )}
                    </div>
                  ))}
                </div>
              )}
              <!-- <a class="cert-link" href="/img/certificates/degree.jpeg" target="_blank" rel="noreferrer">
                View degree certificate
              </a> -->
            </article>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1rem;
  }

  .column-title {
    margin: 0 0 1rem;
    font-size: 1.1rem;
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .timeline-item {
    padding: 1.25rem;
  }

  .timeline-head {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .logo {
    border-radius: 10px;
    object-fit: contain;
    background: var(--bg-muted);
  }

  .timeline-item h4 {
    margin: 0 0 0.25rem;
  }

  .org,
  .dates {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  .timeline-item ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
  }

  .timeline-item li + li {
    margin-top: 0.45rem;
  }

  .achievements {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    padding-left: 3.5rem;
    border-top: 1px solid var(--border);
  }

  .achievement {
    display: grid;
    gap: 0.15rem;
    font-size: 0.9rem;
  }

  .achievement span {
    color: var(--text-muted);
  }

  .cert-link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .timeline-grid {
      grid-template-columns: 1fr;
    }
  }
</style>