---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects, getProject, categoryLabels } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = getProject(slug!);

if (!project) {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${project.title} | Madhura Hande Deshmukh`} description={project.summary}>
  <article class="case-study section">
    <div class="container case-container">
      <a class="back-link" href="/#projects">← Back to projects</a>

      <header class="case-header">
        <p class="section-label">{categoryLabels[project.category]}</p>
        <h1>{project.title}</h1>
        <p class="case-summary">{project.summary}</p>
        <div class="case-meta">
          {project.organization && <span>{project.organization}</span>}
          {project.year && <span>{project.year}</span>}
        </div>
        <ul class="tag-list">
          {project.tags.map((tag) => (
            <li><span class="chip">{tag}</span></li>
          ))}
        </ul>
      </header>

      {project.images && project.images.length > 0 && (
      <section class="case-gallery">
        {project.images.map((image) => (
          <figure class="gallery-item">
            <img
              src={image.src}
              alt={image.caption ?? project.title}
              loading="lazy"
            />

            {image.caption && (
              <figcaption>{image.caption}</figcaption>
            )}
          </figure>
        ))}
      </section>
    )}

      <section class="case-body card">
      <h2>Overview</h2>
      <p>{project.overview}</p>
      
      <h2>My Role</h2>
      <ul>
        {project.role.map((item) => (
          <ul>{item}</ul>
        ))}
      </ul>
      
      <h2>Engineering Highlights</h2>

      <ul>
        {project.engineeringHighlights.map((item) => (
          <ul><li>{item}</li></ul>
        ))}
          </ul>
          
      <h2>Challenges</h2>

      <ul>
        {project.challenges.map((item) => (
          <ul>{item}</ul>
        ))}
      </ul>
    
    <h2>Impact</h2>

    <ul>
      {project.impact.map((item) => (
        <ul>{item}</ul>
      ))}
    </ul>

    <h2>What I learned</h2>

    <ul>
      {project.learnings.map((item) => (
        <ul>{item}</ul>
      ))}
    </ul>
    </section>

 
      <!-- <section class="case-body card">
       
        {project.category === 'medical' && (
          <p class="disclaimer">
            Project descriptions reflect firmware engineering work. Device imagery and proprietary
            implementation details are omitted.
          </p>
        )}
      </section> -->
    </div>
  </article>
</BaseLayout>

<style>
  .case-container {
    max-width: 820px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .case-header h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 2.6rem);
    letter-spacing: -0.03em;
  }

  .case-summary {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0 0 1rem;
  }

  .case-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .case-gallery {

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));

    gap:1rem;

    margin:2rem 0;

}

.gallery-item{

    margin:0;

}

.gallery-item img{

    width:100%;

    height:260px;

    object-fit:contain;

    border-radius:12px;

    transition:.3s;

}

.gallery-item img:hover{

    transform:scale(1.02);

}

.gallery-item figcaption{

    text-align:center;

    margin-top:.5rem;

    color:var(--text-muted);

    font-size:.9rem;

}

  .case-body {
    padding: 1.5rem;
  }

  .case-body h2 {
    margin-top: 0;
  }

  .case-body ul {
    padding-left: 1.1rem;
    color: var(--text-muted);
    display: grid;
    gap: 0.65rem;
  }

  .disclaimer {
    margin-top: 1.5rem;
    padding: 1rem;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--text-muted);
    font-size: 0.92rem;
  }
</style>
